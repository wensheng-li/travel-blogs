<%- include("partials/header.ejs") %>
  <a href="/blogs" class="back-to-blogs">← Back to Blogs</a>
  <hr>
  <div class="container my-5">
    <h1>
      <%= blog.title %>
    </h1>
    <div class="d-flex justify-content-between align-items-center mb-4">
      <p class="text-muted">Published on: <%= blog.date %></p>
      <p class="text-muted">By: <%= blog.author %></p>
      <div class="btn-group">
        <form action="/blogs/<%= blog.id %>/edit" method="get">
          <button type="submit" class="btn btn-outline-primary btn-sm">Edit</button>
        </form>
        <form action="/blogs/<%= blog.id %>/delete" method="post">
          <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this blog?')">
            Delete
          </button>
        </form>

      </div>
    </div>

    <article class="blog-details">
      <img src="<%= blog.image %>" alt="blog image" class="img-fluid mb-4 rounded">

      <div class="blog-body">
        <% blog.content.split(/\r?\n+/).forEach(function(paragraph) { %>
          <% if (paragraph.trim()) { %>
            <p><%= paragraph %></p>
          <% } %>
        <% }); %>
      </div>
    </article>
  </div>
  <%- include("partials/footer.ejs") %>